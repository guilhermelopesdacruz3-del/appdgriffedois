# Copie este arquivo para server/.env e preencha com as credenciais da sua loja.
# Essas chaves são SECRETAS — nunca as coloque em arquivos que vão para o
# front-end (nada com prefixo VITE_) nem em repositórios públicos.

# Gerada em: painel da loja > Configurações > Chave para API
# https://app.lojaintegrada.com.br/painel/configuracao/token (exige plano pago)
LOJA_INTEGRADA_API_KEY=

# Solicitada à Loja Integrada (integrador@lojaintegrada.com.br ou formulário
# oficial). Leva de 5 a 10 dias úteis para ser liberada.
LOJA_INTEGRADA_APP_KEY=

# Confirme a base atual da API em https://api-docs.lojaintegrada.com.br/
# antes de ir para produção — o valor abaixo é o endpoint REST clássico.
LOJA_INTEGRADA_API_BASE_URL=https://api.awsli.com.br/api/v1

# Domínio do seu site (front-end) que terá permissão de chamar este proxy.
# Use "*" apenas em desenvolvimento.
FRONTEND_ORIGIN=*

# Senha de acesso ao painel de administrador (/api/admin). OBRIGATÓRIA para
# que a área de admin funcione.
ADMIN_PASSWORD=

# Segredo usado para assinar o token de admin (HMAC). Opcional — se não
# definir, um valor padrão (inseguro) é usado. Em produção, defina um valor
# longo e aleatório.
ADMIN_SECRET=

PORT=8787
